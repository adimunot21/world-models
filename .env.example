# === World Models Project — Environment Variables ===
# Copy this file to .env and fill in values.
# NEVER commit .env to git.

# WandB (optional — only needed if you enable WandB logging for LeWorldModel)
# WANDB_API_KEY=your_key_here
# WANDB_ENTITY=your_entity
# WANDB_PROJECT=world-models

# LeWorldModel data directory (default: ~/.stable-wm/)
# STABLEWM_HOME=/path/to/lewm/data

# CUDA device (default: cuda:0)
# CUDA_VISIBLE_DEVICES=0
